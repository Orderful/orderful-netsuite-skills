# ============================================================
#  Orderful NetSuite Onboarding — Customer Credentials
# ============================================================
#
#  HOW TO FILL THIS OUT
#   1. Onboarding starts in sandbox — only the SANDBOX block is
#      required right now. Leave the PRODUCTION block blank until
#      the customer is ready to go live.
#   2. Anywhere you see  <PASTE HERE>  replace it with the real value.
#   3. Save. Do NOT commit — this file lives outside the skills repo.
#
# ============================================================


# ------------------------------------------------------------
#  CUSTOMER  (pre-filled by the netsuite-setup skill; edit if wrong)
# ------------------------------------------------------------

CUSTOMER_SLUG=
CUSTOMER_NAME=


# ------------------------------------------------------------
#  ACTIVE ENVIRONMENT
# ------------------------------------------------------------
# Controls which NetSuite credential block the test script uses
# (NS_SB_* vs NS_PROD_*). "sandbox" during onboarding,
# "production" at go-live.
#
# Note: Orderful has ONE API endpoint (api.orderful.com) and the
# API key is global — ENVIRONMENT does NOT affect Orderful calls.

ENVIRONMENT=sandbox


# ============================================================
#  NETSUITE — SANDBOX        <<< FILL IN FOR ONBOARDING >>>
# ============================================================
# All five values come from the customer's SANDBOX NetSuite.
#   ACCOUNT_ID       Setup > Company > Company Information
#                    Sandbox format: 1234567_SB1
#                    *** COPY EXACT CASE *** — the OAuth realm
#                    parameter must match the ID character-for-
#                    character including case. Letter-prefixed IDs
#                    (TD..., MS..., etc.) are usually uppercase in
#                    the NS UI; pasting lowercase silently breaks
#                    auth with no entry in the Login Audit Trail.
#   CONSUMER_KEY     Setup > Integration > Manage Integrations
#   CONSUMER_SECRET  (shown ONCE at integration creation)
#   TOKEN_ID         Setup > Users/Roles > Access Tokens
#   TOKEN_SECRET     (shown ONCE at token creation)
#
# Don't have these yet? See INTEGRATION-RECORD-SETUP.md.

NS_SB_ACCOUNT_ID=<PASTE HERE>
NS_SB_CONSUMER_KEY=<PASTE HERE>
NS_SB_CONSUMER_SECRET=<PASTE HERE>
NS_SB_TOKEN_ID=<PASTE HERE>
NS_SB_TOKEN_SECRET=<PASTE HERE>


# ============================================================
#  NETSUITE — PRODUCTION     <<< LEAVE BLANK UNTIL GO-LIVE >>>
# ============================================================
# Same five fields as sandbox, but from the customer's PRODUCTION
# NetSuite. Production account ID has no suffix: "1234567" (or
# letter-prefixed forms like "TDxxxxxxx" — copy the EXACT case
# shown in Setup > Company > Company Information; lowercase
# letter-prefixed IDs will fail auth silently).
# Fill these in when the customer is ready to cut over to prod.

NS_PROD_ACCOUNT_ID=
NS_PROD_CONSUMER_KEY=
NS_PROD_CONSUMER_SECRET=
NS_PROD_TOKEN_ID=
NS_PROD_TOKEN_SECRET=


# ============================================================
#  ORDERFUL API             <<< FILL IN FOR ONBOARDING >>>
# ============================================================
# Header used by the API: orderful-api-key
# URL (always): https://api.orderful.com
#
# Orderful has a single API endpoint — there is no sandbox URL.
# One key works regardless of which NetSuite environment (sandbox
# or production) you're pointing at.
#
# Source: app.orderful.com > Settings > API Keys for the customer's
# org, or request from the Orderful team if you're internal.

ORDERFUL_API_KEY=<PASTE HERE>


# ------------------------------------------------------------
#  OPTIONAL — customer reference data
# ------------------------------------------------------------
# Fill these in as you learn them; other skills may use them.

CUSTOMER_ISA_ID=
ORDERFUL_ORG_ID=
ORDERFUL_POLLING_BUCKET_IDS=
